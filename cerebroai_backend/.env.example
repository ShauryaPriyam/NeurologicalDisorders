# --- Server ---
# Bind address and port for Uvicorn
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated browser origins for CORS (Next.js dev server by default)
CORS_ORIGINS=http://localhost:3000

# Temporary directory for uploaded scans (created if missing; relative to process CWD unless absolute)
TEMP_DIR=temp

# --- Model 1 — TensorFlow / Keras (.h5) ---
# Paths are relative to the directory containing main.py unless absolute.
TF_BINARY_MODEL_PATH=models/tf/task2_binary_model.h5
TF_MULTI_MODEL_PATH=models/tf/task2_multi_model.h5

# --- Model 2 — PyTorch / "Custom CNN" slot (ResNet18 from 2D CNN notebook) ---
# Full nn.Module or ResNet18 state_dict (fc layer 2 or 3 classes)
PT_BINARY_MODEL_PATH=models/pt/task2_binary_model.pth
PT_MULTI_MODEL_PATH=models/pt/task2_multi_model.pth

# --- Model 3 — Hybrid / "3D PCA SVM" slot ---
# If the .pkl is a full sklearn Pipeline (e.g. scaler + PCA + SVC), inference uses it
# alone; .pth classifiers are optional (only for legacy feature-only .pkl + PyTorch head).
HYBRID_BINARY_PKL_PATH=models/hybrid/task2_binary_features.pkl
HYBRID_BINARY_CLF_PATH=models/hybrid/task2_binary_clf.pth
HYBRID_MULTI_PKL_PATH=models/hybrid/task2_multi_features.pkl
HYBRID_MULTI_CLF_PATH=models/hybrid/task2_multi_clf.pth
# Integer class label that means AD in binary sklearn training (default 1)
# HYBRID_BINARY_AD_LABEL=1
# Comma-separated names for sklearn classes 0,1,2 -> AD,MCI,CN (default)
# HYBRID_MULTI_LABEL_ORDER=AD,MCI,CN
