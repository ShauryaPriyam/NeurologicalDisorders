# Comma-separated list of browser origins allowed to call this API (CORS)
CORS_ORIGINS=http://localhost:3000

# Uvicorn bind address and port
API_HOST=0.0.0.0
API_PORT=8000

# Directory for temporary uploaded scan files (created if missing)
TEMP_DIR=temp

# TensorFlow Keras — point to your .h5 files (relative to main.py unless absolute)
TF_BINARY_MODEL_PATH=models/tf/Task2Brute_model.h5
TF_MULTI_MODEL_PATH=models/tf/Task3Brute_model.h5

PT_BINARY_MODEL_PATH=models/pt/binary_cn_ad_model.pth
PT_MULTI_MODEL_PATH=models/pt/multiclass_cn_mci_ad_model.pth

HYBRID_BINARY_PKL_PATH=models/hybrid/3d_pca_svm_binary_cn_ad.pkl
HYBRID_BINARY_CLF_PATH=models/hybrid/3d_resnet10_binary.pth

HYBRID_MULTI_PKL_PATH=models/hybrid/3d_pca_svm_multiclass_cn_mci_ad.pkl
HYBRID_MULTI_CLF_PATH=models/hybrid/3d_resnet10_multiclass.pth